# Server
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,https://whatsapp.itroots.co.in,https://api.whatsapp.itroots.co.in

# Database
# Coolify can use DATABASE_URL instead of the split DB_* values.
# DATABASE_URL=postgres://user:password@host:5432/database
DB_DIALECT=postgres
DB_AUTO_MIGRATE=false
DB_HOST=localhost
DB_PORT=5432
DB_NAME=whatsapp_platform
DB_USER=postgres
DB_PASS=your_postgres_password
DB_ADMIN_DB=postgres

# JWT
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_64_CHAR_HEX_SECRET
JWT_EXPIRES_IN=7d

# Meta / WhatsApp
META_APP_ID=your_meta_app_id
# Use the Meta App Secret from App settings > Basic, not a WhatsApp access token.
META_APP_SECRET=your_meta_app_secret
META_API_VERSION=v25.0
WEBHOOK_VERIFY_TOKEN=REPLACE_WITH_A_RANDOM_WEBHOOK_TOKEN

# Redis (for BullMQ - optional)
REDIS_HOST=localhost
REDIS_PORT=6379
